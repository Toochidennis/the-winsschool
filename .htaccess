DirectoryIndex index.html
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect direct .html page requests to clean URLs only for GET requests.
  # Uses relative redirects so it works at the domain root or inside a subfolder.
  RewriteCond %{REQUEST_METHOD} =GET
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^(.+?)\.html$ $1 [R=301,L]

  # Internally serve extensionless URLs from matching .html files.
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

  # Remove trailing slash from non-directory extensionless pages.
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ $1 [R=301,L]
</IfModule>
