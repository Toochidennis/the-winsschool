DirectoryIndex index.html
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Serve extensionless URLs from matching .html files (internal rewrite only).
  #
  # We intentionally do NOT redirect .html -> clean URL. That external redirect
  # breaks in subfolder installs (e.g. XAMPP at /wins/) where a missing
  # RewriteBase makes Apache build the redirect from the filesystem path
  # (http://localhost/opt/lampp/htdocs/wins/...) and 404. Both /page and
  # /page.html resolve correctly with the internal rewrite below, at the domain
  # root or inside a subfolder, with no broken redirects.
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>
